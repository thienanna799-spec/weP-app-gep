# ==============================
# Database
# ==============================
# ⚠️  CRITICAL: Use 127.0.0.1, NOT localhost — Node.js >=17 on Windows resolves
#              localhost to IPv6 (::1) first, but MySQL Docker only binds IPv4.
#              Using 'localhost' = ECONNREFUSED = 100% login failure. (See ADR-017)
DATABASE_URL="mysql://root:matkhau@127.0.0.1:3306/bocchongsoc"

# ==============================
# Authentication
# ==============================
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# ==============================
# Firebase Admin (for token verification)
# Place serviceAccount.json inside server/
# ==============================
GOOGLE_APPLICATION_CREDENTIALS="./server/serviceAccount.json"

# ==============================
# App
# ==============================
PORT=3000
NODE_ENV=development
