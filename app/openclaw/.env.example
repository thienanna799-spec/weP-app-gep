# OpenClaw Environment Variables
# Copy this to .env and fill in your values

# =========================================
# AI PROVIDER KEYS (at least one required)
# =========================================
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default provider: gemini | openai | openrouter
OPENCLAW_DEFAULT_PROVIDER=gemini

# =========================================
# AI MEMORY PATH
# =========================================
# Path to the ai/ architecture directory
# Default: ../ai (relative to openclaw/)
AI_MEMORY_PATH=../ai

# Path to GEP codebase root (for drift detection)
GEP_ROOT_PATH=../

# =========================================
# TELEGRAM INTEGRATION (optional)
# =========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# Enable Telegram notifications (true | false)
TELEGRAM_ENABLED=false

# =========================================
# LOGGING
# =========================================
LOG_LEVEL=info
LOG_DIR=./logs

# =========================================
# RUNTIME BEHAVIOR
# =========================================
# Auto-confirm execution plans without prompt (true | false)
OPENCLAW_AUTO_CONFIRM=false

# Max tokens for AI context (adjust per provider)
OPENCLAW_MAX_CONTEXT_TOKENS=100000

# Governance strictness: strict | standard | permissive
OPENCLAW_GOVERNANCE_MODE=strict
